<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>项目跟踪 - 红绣服饰</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link href="/quill.snow.css" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <script src="/i18next.min.js"></script>
</head>
<body>

<!-- 身份验证弹窗 -->
<div id="authModal" class="auth-modal-overlay">
    <div class="auth-modal">
        <h2 data-i18n="modal.title">安全验证</h2>
        <p data-i18n="modal.prompt">请输入项目的访问 Token</p>
        <input type="password" id="tokenInput" placeholder="输入 Token..." data-i18n-placeholder="modal.token_placeholder" />
        <button id="verifyBtn" data-i18n="modal.button">验证并进入</button>
        <div id="authError" class="auth-error" data-i18n="modal.error">Token 错误，请重试</div>
    </div>
</div>

<div class="container" id="appContainer">

    <div class="brand-header">
        <% if (role !== 'supplier') { %>
            <img src="/logo.png" alt="Logo" class="brand-logo" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdib3g9IjAgMCAxMDAgMTAwIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iI2RkZCIvPjwvc3ZnPg=='" />
        <% } %>
        <div class="brand-title" data-i18n="brand.title">项目跟踪系统</div>
        <button class="btn-email-notify" id="emailNotifyBtn" style="display:none;" data-i18n="button.email_notify">📧 发送邮件通知</button>
        <div class="lang-switch">
            <button class="lang-btn active" data-lang="zh">中文</button>
            <button class="lang-btn" data-lang="en">English</button>
        </div>
    </div>

    <div class="project-info-grid">
        <div class="info-item">
            <span class="info-label" data-i18n="info.type">项目类型</span>
            <span class="info-value" id="displayType">加载中...</span>
        </div>
        <div class="info-item">
            <span class="info-label" data-i18n="info.uuid">项目 ID (UUID)</span>
            <span class="info-value mono" id="displayUuid"><%= projectId %></span>
        </div>
        <div class="info-item" id="orderDateContainer" style="display: none;">
            <span class="info-label" data-i18n="info.order_date">下单日期</span>
            <span class="info-value-date" id="displayOrderDate">加载中...</span>
        </div>
        <div class="info-item" id="deliveryDateContainer" style="display: none;">
            <span class="info-label" data-i18n="info.delivery_date">交付日期</span>
            <span class="info-value-date" id="displayDeliveryDate">加载中...</span>
        </div>
        <div class="info-item">
            <span class="info-label" data-i18n="info.status">当前状态</span>
            <span class="info-value highlight" id="displayStatus">加载中...</span>
        </div>
        <div class="info-item">
            <span class="info-label" data-i18n="info.role">当前身份</span>
            <span class="info-value" id="displayRole">验证中...</span>
        </div>
    </div>

    <div class="stepper-container" id="stepperContainer"></div>

    <div class="main-panel">
        <div class="editor-container">
            <div id="editor"></div>
        </div>
        <div class="editor-footer">
            <button class="btn-submit" id="submitBtn" data-i18n="button.save">保存当前记录</button>
        </div>
        <div class="history-section">
            <div class="history-title" data-i18n="history.title">历史记录</div>
            <div class="timeline" id="timelineContainer"></div>
        </div>
    </div>

    <div class="next-step-container" id="nextStepContainer">
        <span class="link-next-step" id="nextStepBtn" data-i18n="button.complete_stage">此阶段已完成</span>
    </div>

    <div class="page-footer">
        &copy; <span id="currentYear"></span>
        <span data-i18n="footer.company">红绣服饰 (Hongxiu Clothing)</span>.
        <span data-i18n="footer.rights">All Rights Reserved</span>.
        | <span data-i18n="footer.slogan">专属定制 · 品质追踪</span>
    </div>

</div>

<!-- 邮件通知弹窗 -->
<div id="emailModal" class="email-modal-overlay" style="display:none;">
    <div class="email-modal">
        <h2 data-i18n="email.title">发送邮件通知</h2>
        <label class="email-label" data-i18n="email.address_label">收件邮箱 <span class="required">*</span></label>
        <textarea id="emailAddresses" class="email-textarea" rows="4" placeholder="每行输入一个邮箱地址" data-i18n-placeholder="email.address_placeholder"></textarea>
        <label class="email-label" data-i18n="email.content_label">邮件内容（选填）</label>
        <textarea id="emailContent" class="email-textarea" rows="4" placeholder="输入通知内容..." data-i18n-placeholder="email.content_placeholder"></textarea>
        <div id="emailError" class="email-error"></div>
        <div class="email-actions">
            <button class="btn-email-cancel" id="emailCancelBtn" data-i18n="email.cancel">取消</button>
            <button class="btn-email-confirm" id="emailConfirmBtn" data-i18n="email.confirm">确定发送</button>
        </div>
    </div>
</div>

<!-- 大图预览 -->
<div id="imagePreviewModal" class="img-preview-modal">
    <div id="modalBg" style="position:absolute; width:100%; height:100%; z-index:20000;" onclick="closeImagePreview()"></div>
    <button class="modal-nav-btn prev" id="modalPrev" onclick="changeImage(-1)">&#10094;</button>
    <img id="previewImage" src="" alt="预览图" style="position:relative; z-index:20001;">
    <button class="modal-nav-btn next" id="modalNext" onclick="changeImage(1)">&#10095;</button>
    <div class="modal-counter" id="modalCounter" style="z-index:20001;">1 / 1</div>
</div>

<!-- 服务端注入配置 -->
<script>
    window.__CONFIG__ = {
        projectId: <%- JSON.stringify(projectId) %>,
        userRole: <%- JSON.stringify(role) %>
    };
</script>

<!-- 第三方库 -->
<script src="/quill.min.js"></script>
<script src="/image-resize.min.js"></script>

<!-- 应用脚本 -->
<script src="/i18n-resources.js"></script>
<script src="/app.js"></script>

</body>
</html>
