    // ====================== 全局变量 ======================
    const PROJECT_ID = '<%= projectId %>';
    const statusMap = { '需求': 0, '准备': 1, '生产': 2, '质检': 3, '运输': 4, '完成': 5 };
    const stepsName = ['需求', '准备', '生产', '质检', '运输', '完成'];
    const stepsId = ['requirement', 'preparation', 'production', 'qa', 'transport', 'done'];

    let BACKEND_DATA = {};
    let state = {};
    let quill;

    const STORAGE_KEY = `tracker_token_${PROJECT_ID}`;
    const LANG_STORAGE_KEY = 'lang';

    // ====================== i18next 初始化 ======================
    function initI18next() {
        const savedLang = localStorage.getItem(LANG_STORAGE_KEY) || 'zh';
        
        i18next.init({
            lng: savedLang,
            resources: i18nResources,
            fallbackLng: 'zh',
            debug: false
        }).then(() => {
            updateAllContent();
            highlightActiveLangButton();
        });
    }

    function updateAllContent() {
        document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            el.textContent = i18next.t(key);
        });

        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
            const key = el.getAttribute('data-i18n-placeholder');
            el.placeholder = i18next.t(key);
        });

        document.title = i18next.t('title');

        if (quill) {
            quill.root.setAttribute('data-placeholder', i18next.t('editor.placeholder'));
        }
    }

    function highlightActiveLangButton() {
        document.querySelectorAll('.lang-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.lang === i18next.language);
        });
    }

    // ====================== 验证逻辑 ======================
    async function verifyToken(token, isAutoLogin = false) {
        const btn = document.getElementById('verifyBtn');
        const errorMsg = document.getElementById('authError');
        const modal = document.getElementById('authModal');
        const appContainer = document.getElementById('appContainer');

        if (!isAutoLogin) {
            btn.innerText = i18next.t('modal.verifying');
            btn.disabled = true;
            errorMsg.style.display = 'none';
        }

        try {
            const response = await fetch('/api/get-project', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId: PROJECT_ID, token: token })
            });
            const result = await response.json();

            if (result.success) {
                localStorage.setItem(STORAGE_KEY, token);
                modal.style.display = 'none';
                appContainer.style.display = 'block';
                
                BACKEND_DATA = result.data;
                const projectData = BACKEND_DATA.project_data || {};

                document.getElementById('displayType').innerText = projectData.type || i18next.t('default.type');
                document.getElementById('displayUuid').innerText = projectData.uuid || PROJECT_ID;
                document.getElementById('displayStatus').innerText = projectData.status || i18next.t('default.unknown');
                
                let roleText = i18next.t('role.visitor');
                if (BACKEND_DATA.role === 'admin') roleText = i18next.t('role.admin');
                else if (BACKEND_DATA.role === 'write') roleText = i18next.t('role.collaborator');
                document.getElementById('displayRole').innerText = roleText;

                const rawNodes = projectData.nodesData || BACKEND_DATA.nodesData || {};
                const normalizedNodes = {};

                Object.keys(rawNodes).forEach(key => {
                    const val = rawNodes[key];
                    if (Array.isArray(val)) {
                        normalizedNodes[key] = val.map(item => ({
                            time: item.time || i18next.t('timeline.early'),
                            html: item.html || ''
                        }));
                    } else if (typeof val === 'object' && val !== null) {
                        let arr = [];
                        if (val.text) arr.push({ time: '订单详情', html: val.text });
                        if (val.logs && Array.isArray(val.logs)) {
                            val.logs.forEach(log => arr.push({ time: '系统日志', html: log }));
                        }
                        normalizedNodes[key] = arr;
                    } else {
                        normalizedNodes[key] = [];
                    }
                });

                stepsId.forEach(step => {
                    if (!normalizedNodes[step]) normalizedNodes[step] = [];
                });

                const realStatusIndex = projectData.status ? (statusMap[projectData.status] || 0) : 0;
                
                state = {
                    maxStepIndex: realStatusIndex,
                    activeStepIndex: realStatusIndex,
                    nodesData: normalizedNodes
                };
                
                initApp(); 
            } else {
                localStorage.removeItem(STORAGE_KEY);
                if (!isAutoLogin) {
                    errorMsg.innerText = result.message || i18next.t('modal.error');
                    errorMsg.style.display = 'block';
                }
                btn.innerText = i18next.t('modal.button');
                btn.disabled = false;
                if(isAutoLogin) modal.style.display = 'flex';
            }
        } catch (error) {
            console.error(error);
            if (!isAutoLogin) {
                errorMsg.innerText = '网络错误，请稍后再试';
                errorMsg.style.display = 'block';
            }
            btn.innerText = i18next.t('modal.button');
            btn.disabled = false;
            if(isAutoLogin) modal.style.display = 'flex';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        initI18next();

        const savedToken = localStorage.getItem(STORAGE_KEY);
        if (savedToken) {
            document.getElementById('verifyBtn').innerText = i18next.t('default.verifying');
            verifyToken(savedToken, true);
        }

        document.querySelectorAll('.lang-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const newLang = btn.dataset.lang;
                i18next.changeLanguage(newLang, () => {
                    localStorage.setItem(LANG_STORAGE_KEY, newLang);
                    updateAllContent();
                    highlightActiveLangButton();
                    if (state.nodesData) {
                        renderStepper();
                        renderTimeline();
                    }
                });
            });
        });
    });

    document.getElementById('verifyBtn').addEventListener('click', () => {
        const token = document.getElementById('tokenInput').value.trim();
        if (token) verifyToken(token, false);
    });

    document.getElementById('tokenInput').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            const token = this.value.trim();
            if (token) verifyToken(token, false);
        }
    });

    function initApp() {
        const editorContainer = document.querySelector('.editor-container');
        const editorFooter = document.querySelector('.editor-footer');
        
        if (BACKEND_DATA.role === 'read') {
            if (editorContainer) editorContainer.style.display = 'none';
            if (editorFooter) editorFooter.style.display = 'none';
        } else {
            if (editorContainer) editorContainer.style.display = 'block';
            if (editorFooter) editorFooter.style.display = 'flex';
            
            if (!quill) {

                const icons = Quill.import('ui/icons');
                icons['attachment'] = '<svg viewbox="0 0 24 24"><path d="M16.5,6v11.5c0,2.21-1.79,4-4,4s-4-1.79-4-4V5c0-1.38,1.12-2.5,2.5-2.5s2.5,1.12,2.5,2.5v10.5c0,0.55-0.45,1-1,1s-1-0.45-1-1V6H10v9.5c0,1.38,1.12,2.5,2.5,2.5s2.5-1.12,2.5-2.5V5c0-2.21-1.79-4-4-4S7,2.79,7,5v12.5c0,3.31,2.69,6,6,6s6-2.69,6-6V6H16.5z"/></svg>';
                
                quill = new Quill('#editor', {
                    theme: 'snow',
                    placeholder: i18next.t('editor.placeholder'),
                    modules: {
                        toolbar: {
                            container: [
                                [{ 'header': [1, 2, false] }],
                                ['bold', 'italic', 'underline', 'strike'],
                                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                                ['blockquote', 'code-block'],
                                ['image', 'attachment', 'link', 'video'],
                                ['clean']
                            ],
                            handlers: {
                                'image': imageHandler,
                                 'attachment': fileHandler 
                            }
                        },
                        imageResize: {
                            displaySize: true,
                            modules: ['Resize', 'DisplaySize', 'Toolbar']
                        }
                    }
                });

                
                // ====================== 新增：拦截粘贴和拖拽图片 ======================
                // 1. 拦截 Ctrl+V 粘贴
                quill.root.addEventListener('paste', (e) => {
                    if(e.clipboardData && e.clipboardData.items) {
                        let hasImage = false;
                        Array.from(e.clipboardData.items).forEach(item => {
                            if (item.type.indexOf('image/') === 0) {
                                hasImage = true;
                                const file = item.getAsFile();
                                if (file) uploadAndInsertImage(file);
                            }
                        });
                        // 如果剪贴板里有图片，阻止默认的粘贴行为(阻止Base64转换)
                        if (hasImage) {
                            e.preventDefault(); 
                        }
                    }
                });

                // 2. 拦截文件拖拽到编辑器
                quill.root.addEventListener('drop', (e) => {
                    if (e.dataTransfer && e.dataTransfer.files) {
                        let hasImage = false;
                        Array.from(e.dataTransfer.files).forEach(file => {
                            if (file.type.indexOf('image/') === 0) {
                                hasImage = true;
                                uploadAndInsertImage(file);
                            }
                        });
                        // 如果拖进来的是图片，阻止浏览器默认打开图片的动作及 Quill 的 Base64 转换
                        if (hasImage) {
                            e.preventDefault(); 
                        }
                    }
                });
                // ===================================================================
            }
        }
        renderStepper();
        renderTimeline();
        updateAllContent();
    }

    let currentImageList = []; // 存储当前预览组的所有图片URL
    let currentIndex = 0;      // 当前显示的索引
    
    document.getElementById('timelineContainer').addEventListener('click', function(e) {
        if (e.target.tagName === 'IMG') {
            // 1. 查找这张图是否属于一个图集 (n8n 生成的 .img-gallery)
            const gallery = e.target.closest('.img-gallery');
            
            if (gallery) {
                // 获取该图集下所有的图片地址
                const allImgs = Array.from(gallery.querySelectorAll('img'));
                currentImageList = allImgs.map(img => img.src);
                currentIndex = currentImageList.indexOf(e.target.src);
            } else {
                // 如果不是图集，就只有这一张图
                currentImageList = [e.target.src];
                currentIndex = 0;
            }
            
            openImagePreview();
        }
    });

    function openImagePreview() {
        const modal = document.getElementById('imagePreviewModal');
        updateModalImage();
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    
    function updateModalImage() {
        const fullImg = document.getElementById('previewImage');
        const counter = document.getElementById('modalCounter');
        const prevBtn = document.getElementById('modalPrev');
        const nextBtn = document.getElementById('modalNext');
    
        fullImg.src = currentImageList[currentIndex];
        counter.innerText = `${currentIndex + 1} / ${currentImageList.length}`;
    
        // 如果只有一张图，隐藏导航按钮
        if (currentImageList.length <= 1) {
            prevBtn.style.display = 'none';
            nextBtn.style.display = 'none';
        } else {
            prevBtn.style.display = 'block';
            nextBtn.style.display = 'block';
        }
    }
    
    // 切换图片 (n 是 +1 或 -1)
    function changeImage(n) {
        currentIndex += n;
        
        // 循环切换逻辑
        if (currentIndex >= currentImageList.length) currentIndex = 0;
        if (currentIndex < 0) currentIndex = currentImageList.length - 1;
        
        updateModalImage();
    }
    
    function closeImagePreview() {
        document.getElementById('imagePreviewModal').style.display = 'none';
        document.body.style.overflow = 'auto';
    }
    
    // 增加键盘支持 (左右键翻页，ESC关闭)
    document.addEventListener('keydown', function(e) {
        const modal = document.getElementById('imagePreviewModal');
        if (modal.style.display === 'flex') {
            if (e.key === 'ArrowLeft') changeImage(-1);
            if (e.key === 'ArrowRight') changeImage(1);
            if (e.key === 'Escape') closeImagePreview();
        }
    });

    // ====================== 通用图片上传逻辑 ======================
    // 处理具体的图片文件上传并插入到编辑器
    async function uploadAndInsertImage(file, index = null) {
        if (file.size > 5 * 1024 * 1024) {
            alert('图片大小不能超过 5MB');
            return;
        }

        const formData = new FormData();
        formData.append('image', file);

        // 为了防止多次粘贴时光标丢失，先获取当前光标位置
        let insertIndex = index;
        if (insertIndex === null) {
            const range = quill.getSelection(true);
            insertIndex = range ? range.index : quill.getLength();
        }

        // 插入一个临时的“上传中”提示（可选体验优化）
        quill.insertText(insertIndex, '[图片上传中...]', { color: '#999' });

        try {
            const response = await fetch('/api/upload-image', {
                method: 'POST',
                body: formData
            });
            const data = await response.json();

            // 删除“上传中”提示
            quill.deleteText(insertIndex, '[图片上传中...]'.length);

            if (data.success && data.url) {
                // 插入真实的图片外链
                quill.insertEmbed(insertIndex, 'image', data.url);
                quill.setSelection(insertIndex + 1);
            } else {
                alert('图片上传失败：' + (data.message || '未知错误'));
            }
        } catch (error) {
            console.error('图片上传出错', error);
            quill.deleteText(insertIndex, '[图片上传中...]'.length);
            alert('上传失败，请检查网络或稍后重试');
        }
    }

    // Quill 工具栏图片按钮处理函数
    function imageHandler() {
        const input = document.createElement('input');
        input.setAttribute('type', 'file');
        input.setAttribute('accept', 'image/*');
        input.click();

        input.onchange = () => {
            const file = input.files[0];
            if (file) {
                uploadAndInsertImage(file);
            }
        };
    }

    // Quill 附件上传处理函数
    function fileHandler() {
        const input = document.createElement('input');
        input.setAttribute('type', 'file');
        // 不限制类型，允许所有文件
        input.click();

        input.onchange = async () => {
            const file = input.files[0];
            if (!file) return;

            // 限制文件大小（例如 20MB）
            if (file.size > 20 * 1024 * 1024) {
                alert(i18next.t('alert.file_limit') || '文件大小不能超过 20MB');
                return;
            }

            const range = quill.getSelection(true);
            const uploadingText = (i18next.t('alert.file_uploading') || '[上传中...] ') + file.name;
            
            // 先在编辑器里插入“[上传中...] 文件名”占位符
            quill.insertText(range.index, uploadingText, { color: '#999' });

            const formData = new FormData();
            formData.append('file', file); // 这里的字段名 'file' 需根据你后端的接收要求调整

            try {
                // 请求后端的上传附件接口
                const response = await fetch('/api/upload-file', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                // 删除刚才的占位符文本
                quill.deleteText(range.index, uploadingText.length);

                if (data.success && data.url) {
                    // 插入带 📎 图标的文件名，并转为超链接
                    const insertText = `📎 ${file.name}`;
                    quill.insertText(range.index, insertText);
                    quill.setSelection(range.index, insertText.length);
                    quill.format('link', data.url); // 设置超链接
                    
                    // 将光标移到链接后面，并清除链接格式，方便继续输入文字
                    quill.setSelection(range.index + insertText.length);
                    quill.format('link', false);
                    quill.insertText(range.index + insertText.length, ' '); 
                } else {
                    alert((i18next.t('alert.file_fail') || '文件上传失败：') + (data.message || '未知错误'));
                }
            } catch (error) {
                console.error('文件上传出错', error);
                // 发生异常时也删除占位符
                quill.deleteText(range.index, uploadingText.length);
                alert('上传失败，请检查网络或稍后重试');
            }
        };
    }

    function renderStepper() {
        const container = document.getElementById('stepperContainer');
        container.innerHTML = '';
        
        stepsName.forEach((title, index) => {
            const isLocked = index > state.maxStepIndex;             
            const isActiveView = index === state.activeStepIndex;    
            
            const node = document.createElement('div');
            let classNames = ['step-node'];
            
            if (isLocked) classNames.push('locked'); 
            else {
                if (isActiveView) classNames.push('active'); 
                else classNames.push('completed'); 
            }
            
            node.className = classNames.join(' ');
            const translatedTitle = i18next.t(`step.${title}`);
            node.innerHTML = `<div class="step-oval">${translatedTitle}</div>`;
            
            if (!isLocked) {
                node.onclick = () => { 
                    state.activeStepIndex = index; 
                    renderStepper(); 
                    renderTimeline(); 
                    // 移动端点击自动滚动居中
                    if (window.innerWidth <= 768) {
                        node.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                    }
                };
            }
            
            container.appendChild(node);
            
            if (index < stepsName.length - 1) {
                const line = document.createElement('div');
                let lineClass = 'step-line';
                if (index < state.maxStepIndex) lineClass += ' completed'; 
                else if (index === state.maxStepIndex) lineClass += ' half-active'; 
                line.className = lineClass;
                container.appendChild(line);
            }
        });

        const nextContainer = document.getElementById('nextStepContainer');
        if (BACKEND_DATA.role === 'read' || state.maxStepIndex >= stepsName.length - 1 || state.activeStepIndex !== state.maxStepIndex) {
            nextContainer.style.display = 'none';
        } else {
            nextContainer.style.display = 'flex';
        }
    }

    function renderTimeline() {
        const stepId = stepsId[state.activeStepIndex];
        let records = state.nodesData[stepId] || [];
        
        if (stepId === 'requirement') {
            const creationRecords = records.filter(r => r.time && r.time.includes('项目创建'));
            const otherRecords = records.filter(r => !r.time || !r.time.includes('项目创建'));
            records = [...creationRecords, ...otherRecords];
        }

        const container = document.getElementById('timelineContainer');
        if (records.length === 0) {
            container.innerHTML = `<p style="text-align:center; color:#ccc; padding:20px;">${i18next.t('timeline.no_records')}</p>`;
            return;
        }
        
        container.innerHTML = [...records].reverse().map(item => {
            let displayTime = item.time || i18next.t('timeline.early');
            if (displayTime !== i18next.t('timeline.early') && !displayTime.includes('UTC+8') && !displayTime.match(/[a-zA-Z]/)) {
               displayTime += ' (UTC+8)';
            }
            
            let extraClass = '';
            if (displayTime.includes('项目创建')) {
                extraClass = 'starting-record';
            }

            const optimizedHtml = (item.html || '').replace(/<img /g, '<img loading="lazy" ');

            return `
            <div class="timeline-item ${extraClass}">
                <div class="timeline-divider"><div class="timeline-dot"></div></div>
                <div class="timeline-content">
                    <div class="timeline-time">${displayTime}</div>
                    <div class="timeline-html">${item.html || ''}</div>
                </div>
            </div>`;
        }).join('');
    }

    // ====================== 保存按钮 ======================
    document.getElementById('submitBtn').addEventListener('click', async () => {
        if (BACKEND_DATA.role === 'read') return;
        if (!quill) return;

        if (quill.getLength() <= 1 && !quill.root.innerHTML.includes('<img')) {
            alert(i18next.t('alert.empty') || "内容为空");
            return;
        }

        const html = quill.root.innerHTML;
        const stepId = stepsId[state.activeStepIndex]; 
        const now = new Date();
        const time = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')} ${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')} (UTC+8)`;
        
        const newRecord = { time, html };

        if (!state.nodesData[stepId]) state.nodesData[stepId] = [];
        state.nodesData[stepId].push(newRecord);
        quill.setContents([{ insert: '\n' }]);
        renderTimeline();

        const btn = document.getElementById('submitBtn');
        const originalText = btn.innerText;
        btn.innerText = "保存中...";
        btn.disabled = true;

        try {
            const res = await fetch('/api/append-record', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    projectId: PROJECT_ID, 
                    stepId: stepId,
                    newRecord: newRecord 
                })
            });

            const data = await res.json();
            if (data.success) {
                btn.innerText = "已保存 ✓";
                setTimeout(() => { 
                    btn.innerText = originalText; 
                    btn.disabled = false; 
                }, 1200);
            } else {
                throw new Error("保存失败");
            }
        } catch(e) {
            alert(i18next.t('alert.save_fail') || "保存失败");
            state.nodesData[stepId].pop();
            renderTimeline();
            btn.innerText = originalText;
            btn.disabled = false;
        }
    });

    // ====================== 【核心修改】此阶段已完成按钮 ======================
    document.getElementById('nextStepBtn').addEventListener('click', async () => {
        if (BACKEND_DATA.role !== 'write' && BACKEND_DATA.role !== 'admin') return;
        if (state.activeStepIndex !== state.maxStepIndex) return;
    
        const confirmed = confirm(i18next.t('confirm.complete_stage') || "确认提交“此阶段已完成”？\n此操作将通知管理员，正在更新项目进展。");
        if (!confirmed) return;
    
        const btn = document.getElementById('nextStepBtn');
        const originalText = btn.innerText;
        btn.innerText = "处理中...";
        btn.style.pointerEvents = "none";
    
        const payload = {
            projectId: PROJECT_ID,
            stepId: stepsId[state.maxStepIndex],
            newRecord: {
                time: `${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })} (UTC+8)`,
                html: `<p style="color:#aa0000; font-weight:bold;">【系统通知】此阶段已完成，已通知管理员更新进展</p>`
            },
            action: "complete_current_stage" 
        };
    
        try {
            const res = await fetch('/api/append-record', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
    
            const data = await res.json();
            if (data.success) {
                alert(i18next.t('alert.complete_success') || "已通知管理员，正在更新项目进展");
                btn.innerText = "已提交完成";
                btn.style.color = "#888";
                btn.style.pointerEvents = "none";
            } else {
                throw new Error("n8n 返回失败");
            }
        } catch (e) {
            console.error("请求失败", e);
            alert(i18next.t('alert.complete_fail') || "通知管理员失败，请稍后重试");
            btn.innerText = originalText;
            btn.style.pointerEvents = "auto";
        }
    });

    // ====================== 动态年份 ======================
    document.getElementById('currentYear').innerText = new Date().getFullYear();
</script>
</body>
</html>
